# GEMINI_API_KEY: Required for Gemini AI API calls.
# Set this in .env.local for local development or in the Secrets panel for deployment.
GEMINI_API_KEY="YOUR_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="http://localhost:3000"

# GROQ_API_KEY: Optional. Set this in .env.local or the Secrets panel if you wish to use Groq.
GROQ_API_KEY="YOUR_GROQ_API_KEY"

# OPENROUTER_API_KEY: Optional. Set this in .env.local or the Secrets panel if you wish to use OpenRouter.
OPENROUTER_API_KEY="YOUR_OPENROUTER_API_KEY"
